# Environment overrides for Playwright e2e tests.
# E2E_TEST_USER bypasses Google SSO - only @dxw.com addresses are accepted.
# Do not commit real credentials here. This file should not be used in production.
E2E_TEST_USER=e2e@dxw.com
SESSION_SECRET=e2e-test-secret-not-for-production
BASE_URL=http://localhost:3000

# Stub GitHub App credentials - not used during e2e tests but required for the server to start.
APP_ID=1
PRIVATE_KEY=dGVzdA==
CLIENT_ID=test-client-id
CLIENT_SECRET=test-client-secret
WEBHOOK_SECRET=test-webhook-secret
REDIRECT_URL_BASE=http://localhost:3000

