{% import "./macros.njk" as macros %}

<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>Towtruck</title>
    <meta name="description" content="" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🚛</text></svg>" />
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>tailwind.config = { darkMode: 'class' }</script>
    <script>
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="bg-slate-200 text-slate-900 dark:bg-slate-950 dark:text-slate-100">
    {% set baseUrl = dPlusBaseUrl if dPlusMode else (govpressBaseUrl if govpressMode else (opsBaseUrl if opsMode else "/" + org)) %}
    <header class="bg-slate-600 dark:bg-slate-900 text-white">
      <nav class="w-full flex items-center gap-3 px-4 py-2 border-b-4 border-slate-700 dark:border-slate-950">
        <a href="/" class="text-slate-300 hover:text-white transition-colors" aria-label="Back to home">
          <i class="bx bx-arrow-back text-xl"></i>
        </a>
        <h1 class="text-xl font-bold flex-1">Towtruck</h1>
        {% if dPlusMode %}
        <a href="/{{ org }}" class="inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-sm font-medium transition-colors bg-slate-500 text-white border-slate-400 hover:bg-slate-400">
          Exit D+ mode
        </a>
        {% elif govpressMode %}
        <a href="/{{ org }}" class="inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-sm font-medium transition-colors bg-slate-500 text-white border-slate-400 hover:bg-slate-400">
          Exit GovPress mode
        </a>
        {% elif opsMode %}
        <a href="/{{ org }}" class="inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-sm font-medium transition-colors bg-slate-500 text-white border-slate-400 hover:bg-slate-400">
          Exit Ops mode
        </a>
        {% else %}
        <a href="/{{ org }}/d-plus" class="inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-sm font-medium transition-colors bg-purple-600 text-white border-purple-500 hover:bg-purple-500">
          <i class="bx bx-rocket"></i>
          D+ mode
        </a>
        <a href="/{{ org }}/govpress" class="inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-sm font-medium transition-colors bg-orange-600 text-white border-orange-500 hover:bg-orange-500">
          <i class="bx bx-globe"></i>
          GovPress mode
        </a>
        <a href="/{{ org }}/ops" class="inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-sm font-medium transition-colors bg-cyan-600 text-white border-cyan-500 hover:bg-cyan-500">
          <i class="bx bx-server"></i>
          Ops mode
        </a>
        {% endif %}
        <button id="theme-toggle" aria-label="Toggle dark mode"
          class="text-slate-200 hover:text-white transition-colors p-1 rounded-lg hover:bg-slate-500 dark:hover:bg-slate-700">
          <i id="theme-icon" class="bx text-xl"></i>
        </button>
      </nav>
    </header>

    {% if dPlusMode %}
    <div class="bg-purple-600 dark:bg-purple-700 border-b-2 border-purple-800 dark:border-purple-900 px-4 py-2 text-white font-semibold text-sm flex items-center gap-3">
      <i class="bx bx-info-circle text-base"></i>
      <span>This dashboard shows only repos marked D+, delivery-plus, or internal.</span>
    </div>
    {% elif govpressMode %}
    <div class="bg-orange-600 dark:bg-orange-700 border-b-2 border-orange-800 dark:border-orange-900 px-4 py-2 text-white font-semibold text-sm flex items-center gap-3">
      <i class="bx bx-info-circle text-base"></i>
      <span>This dashboard shows only repos marked GovPress.</span>
    </div>
    {% elif opsMode %}
    <div class="bg-cyan-600 dark:bg-cyan-700 border-b-2 border-cyan-800 dark:border-cyan-900 px-4 py-2 text-white font-semibold text-sm flex items-center gap-3">
      <i class="bx bx-info-circle text-base"></i>
      <span>This dashboard shows only repos marked dalmatian or tech-ops.</span>
    </div>
    {% endif %}

    <div class="container mx-auto flex flex-col mt-3 space-y-3">
      <div class="bg-slate-100 dark:bg-slate-900 rounded-lg border-b-4 border-slate-300 dark:border-slate-950 space-y-2">
        <h2 class="bg-slate-50 dark:bg-slate-800 rounded-t-lg border-b-2 border-slate-200 dark:border-slate-900 text-base font-bold px-4 py-2 flex items-center gap-3">
          <span>{{ org }}</span>
          <span class="text-xs font-medium text-slate-500 dark:text-slate-400">{{ totalRepos }} repos tracked</span>
          <span class="text-xs font-medium text-red-600 dark:text-red-400">Critical: {{ totalCriticalVulnerabilities }}</span>
          <span class="text-xs font-medium text-yellow-600 dark:text-yellow-400">Total: {{ totalVulnerabilities }}</span>
          {% if dPlusMode or govpressMode or opsMode %}<span class="text-xs font-medium text-blue-600 dark:text-blue-400">Open bot PRs: {{ totalOpenBotPrs }}</span>{% endif %}
        </h2>

        <!-- Controls box: filters, sorts, save, saved configurations -->
        <div class="mx-4 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 divide-y divide-slate-200 dark:divide-slate-700">

          <!-- Alert filters + sort row -->
          <div class="p-2 flex flex-wrap items-center gap-2">
            <!-- Critical alerts filter (toggles off when already active) -->
            {% if alertFilter === 'criticalOnly' %}
              {% set criticalParams = baseUrl %}
              {% set criticalSep = "?" %}
              {% if sortBy %}{% set criticalParams = criticalParams + criticalSep + "sortBy=" + sortBy %}{% set criticalSep = "&" %}{% endif %}
              {% if sortDirection %}{% set criticalParams = criticalParams + criticalSep + "sortDirection=" + sortDirection %}{% set criticalSep = "&" %}{% endif %}
              {% if tag %}{% set criticalParams = criticalParams + criticalSep + "tag=" + tag %}{% endif %}
            {% else %}
              {% set criticalParams = baseUrl + "?alertFilter=criticalOnly" %}
              {% if sortBy %}{% set criticalParams = criticalParams + "&sortBy=" + sortBy %}{% endif %}
              {% if sortDirection %}{% set criticalParams = criticalParams + "&sortDirection=" + sortDirection %}{% endif %}
              {% if tag %}{% set criticalParams = criticalParams + "&tag=" + tag %}{% endif %}
            {% endif %}
            <a href="{{ criticalParams }}" class="inline-flex items-center rounded-full border px-3 py-1 text-sm font-medium transition-colors {% if alertFilter === 'criticalOnly' %}bg-red-700 text-white border-red-700 dark:bg-red-600 dark:border-red-600{% else %}bg-red-200 text-red-700 border-red-400 hover:bg-red-300 dark:bg-red-950 dark:text-red-300 dark:border-red-800 dark:hover:bg-red-900{% endif %}">
              Critical only
            </a>

            <!-- Any alerts filter (toggles off when already active) -->
            {% if alertFilter === 'anyAlerts' %}
              {% set anyAlertsParams = baseUrl %}
              {% set anyAlertsSep = "?" %}
              {% if sortBy %}{% set anyAlertsParams = anyAlertsParams + anyAlertsSep + "sortBy=" + sortBy %}{% set anyAlertsSep = "&" %}{% endif %}
              {% if sortDirection %}{% set anyAlertsParams = anyAlertsParams + anyAlertsSep + "sortDirection=" + sortDirection %}{% set anyAlertsSep = "&" %}{% endif %}
              {% if tag %}{% set anyAlertsParams = anyAlertsParams + anyAlertsSep + "tag=" + tag %}{% endif %}
            {% else %}
              {% set anyAlertsParams = baseUrl + "?alertFilter=anyAlerts" %}
              {% if sortBy %}{% set anyAlertsParams = anyAlertsParams + "&sortBy=" + sortBy %}{% endif %}
              {% if sortDirection %}{% set anyAlertsParams = anyAlertsParams + "&sortDirection=" + sortDirection %}{% endif %}
              {% if tag %}{% set anyAlertsParams = anyAlertsParams + "&tag=" + tag %}{% endif %}
            {% endif %}
            <a href="{{ anyAlertsParams }}" class="inline-flex items-center rounded-full border px-3 py-1 text-sm font-medium transition-colors {% if alertFilter === 'anyAlerts' %}bg-yellow-600 text-white border-yellow-600 dark:bg-yellow-500 dark:border-yellow-500{% else %}bg-yellow-200 text-yellow-700 border-yellow-400 hover:bg-yellow-300 dark:bg-yellow-950 dark:text-yellow-300 dark:border-yellow-800 dark:hover:bg-yellow-900{% endif %}">
              Any alerts
            </a>

            <!-- Sort dropdown -->
            <div class="flex items-center gap-1" data-testid="sort-controls">
              <label for="sort-select" class="text-xs text-slate-500 dark:text-slate-400 font-medium">Sort:</label>
              <select id="sort-select" class="rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-200 text-sm px-2 py-1 focus:outline-none focus:ring-2 focus:ring-slate-400 dark:focus:ring-slate-500 cursor-pointer"
                onchange="window.location.href=this.value">
                {% set defaultParams = baseUrl %}
                {% set defaultSep = "?" %}
                {% if alertFilter %}{% set defaultParams = defaultParams + defaultSep + "alertFilter=" + alertFilter %}{% set defaultSep = "&" %}{% endif %}
                {% if tag %}{% set defaultParams = defaultParams + defaultSep + "tag=" + tag %}{% endif %}
                <option value="{{ defaultParams }}" {% if not sortBy %}selected{% endif %}>Default</option>
                {% set sortOptions = [
                  { name: "Critical alerts", id: "criticalSeverityAlerts" },
                  { name: "Total alerts", id: "totalOpenAlerts" },
                  { name: "Open issues", id: "openIssues" },
                  { name: "Open bot PRs", id: "openBotPrCount" },
                  { name: "Open PRs", id: "openPrCount" },
                  { name: "Updated at", id: "updatedAt" },
                  { name: "Most recent PR", id: "mostRecentPrOpenedAt" },
                  { name: "Oldest open PR", id: "oldestOpenPrOpenedAt" },
                  { name: "Last bot PR closed", id: "mostRecentBotPrClosedAt" },
                  { name: "Most recent issue", id: "mostRecentIssueOpenedAt" },
                  { name: "Oldest open issue", id: "oldestOpenIssueOpenedAt" }
                ] %}
                {% for opt in sortOptions %}
                  {% set optParams = baseUrl + "?sortBy=" + opt.id + "&sortDirection=asc" %}
                  {% if alertFilter %}{% set optParams = optParams + "&alertFilter=" + alertFilter %}{% endif %}
                  {% if tag %}{% set optParams = optParams + "&tag=" + tag %}{% endif %}
                  <option value="{{ optParams }}" {% if sortBy === opt.id and sortDirection === "asc" %}selected{% endif %}>{{ opt.name }} ↓</option>
                  {% set optParamsDesc = baseUrl + "?sortBy=" + opt.id + "&sortDirection=desc" %}
                  {% if alertFilter %}{% set optParamsDesc = optParamsDesc + "&alertFilter=" + alertFilter %}{% endif %}
                  {% if tag %}{% set optParamsDesc = optParamsDesc + "&tag=" + tag %}{% endif %}
                  <option value="{{ optParamsDesc }}" {% if sortBy === opt.id and sortDirection === "desc" %}selected{% endif %}>{{ opt.name }} ↑</option>
                {% endfor %}
              </select>
            </div>

            <!-- View toggle -->
            <div class="ml-auto inline-flex rounded-lg border border-slate-300 dark:border-slate-600 overflow-hidden text-sm">
              <button id="view-cards" class="px-3 py-1 flex items-center gap-1 transition-colors bg-slate-700 text-white dark:bg-slate-200 dark:text-slate-900" aria-label="Card view">
                <i class="bx bx-grid-alt"></i> Cards
              </button>
              <button id="view-rows" class="px-3 py-1 flex items-center gap-1 transition-colors bg-slate-200 text-slate-700 hover:bg-slate-300 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700" aria-label="Row view">
                <i class="bx bx-list-ul"></i> Rows
              </button>
            </div>
          </div>


          <!-- Save / saved configurations row -->
          <div class="p-2 flex flex-wrap items-center gap-2">

            <!-- Saved configs -->
            {% if savedConfigurations and savedConfigurations.length %}
            {% for config in savedConfigurations %}
            <div class="flex items-center">
              <a href="{{ config.applyUrl | safe }}" class="inline-flex items-center gap-1 rounded-l-full border px-2.5 py-0.5 text-xs font-medium transition-colors {% if config.id === activeConfigId %}bg-slate-700 text-white border-slate-700 dark:bg-slate-200 dark:text-slate-900 dark:border-slate-200{% else %}bg-slate-200 text-slate-700 border-slate-400 hover:bg-slate-300 dark:bg-slate-700 dark:text-slate-200 dark:border-slate-600 dark:hover:bg-slate-600{% endif %}">
                <i class="bx bx-bookmark text-xs"></i>
                {{ config.name }}
              </a>
              <form method="POST" action="/{{ org }}/saved-configurations/{{ config.id }}/delete" class="inline">
                <input type="hidden" name="sortBy" value="{{ sortBy }}" />
                <input type="hidden" name="sortDirection" value="{{ sortDirection }}" />
                <input type="hidden" name="tag" value="{{ tag }}" />
                <input type="hidden" name="alertFilter" value="{{ alertFilter }}" />
                <button type="submit" title="Delete" class="inline-flex items-center rounded-r-full border-t border-r border-b px-1.5 py-0.5 text-xs transition-colors bg-slate-200 text-slate-400 border-slate-400 hover:bg-red-100 hover:text-red-600 hover:border-red-400 dark:bg-slate-700 dark:text-slate-500 dark:border-slate-600 dark:hover:bg-red-950 dark:hover:text-red-400 dark:hover:border-red-800">
                  <i class="bx bx-x text-sm"></i>
                </button>
              </form>
            </div>
            {% endfor %}

            {% if activeConfigId %}
            <a href="{{ baseUrl }}" class="inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-xs font-medium transition-colors bg-slate-200 text-slate-700 border-slate-400 hover:bg-slate-300 dark:bg-slate-800 dark:text-slate-200 dark:border-slate-600 dark:hover:bg-slate-700">
              <i class="bx bx-reset text-xs"></i>
              Clear
            </a>
            {% endif %}
            {% endif %}

            <!-- Save new config -->
            <details class="group/save ml-auto">
              <summary class="list-none cursor-pointer [&::-webkit-details-marker]:hidden inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-xs font-medium transition-colors bg-slate-200 text-slate-700 border-slate-400 hover:bg-slate-300 dark:bg-slate-800 dark:text-slate-200 dark:border-slate-600 dark:hover:bg-slate-700">
                <i class="bx bx-bookmark-plus text-sm"></i>
                Save configuration
              </summary>
              <div class="absolute z-10 mt-1 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg shadow-lg p-3">
                <form method="POST" action="/{{ org }}/saved-configurations" class="flex items-center gap-2">
                  <input type="hidden" name="sortBy" value="{{ sortBy }}" />
                  <input type="hidden" name="sortDirection" value="{{ sortDirection }}" />
                  <input type="hidden" name="tag" value="{{ tag }}" />
                  <input type="hidden" name="alertFilter" value="{{ alertFilter }}" />
                  <input type="text" name="name" placeholder="Name (optional)"
                    class="rounded border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-slate-100 px-2 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-slate-400 w-44"
                  />
                  <button type="submit" class="inline-flex items-center gap-1 rounded-full border px-2.5 py-1 text-xs font-medium transition-colors bg-slate-700 text-white border-slate-700 hover:bg-slate-600 dark:bg-slate-200 dark:text-slate-900 dark:border-slate-200 dark:hover:bg-slate-300">
                    <i class="bx bx-save"></i>
                    Save
                  </button>
                </form>
              </div>
            </details>

          </div>


        </div>

        <!-- Card grid -->
        <div id="card-view" class="mx-4 mb-4 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
          {% for repo in repos %}
          <div class="rounded-lg border flex flex-col shadow-sm bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700">

            <!-- Card header -->
            <div class="p-4 border-b border-slate-100 dark:border-slate-700">
              <div class="flex flex-wrap items-center gap-2">
                <a target="_blank" class="text-lg font-semibold text-slate-600 dark:text-slate-300 hover:underline" href="{{repo.htmlUrl}}">{{ repo.name }}</a>
                {% if repo.language %}
                <span class="text-xs text-{{ repo.languageColor }}-600 dark:text-{{ repo.languageColor }}-400 border-{{ repo.languageColor }}-600 dark:border-{{ repo.languageColor }}-400 border rounded-lg py-0.5 px-2">{{ repo.language }}</span>
                {% endif %}
              </div>

              {% if repo.totalOpenAlerts !== undefined %}
              <div class="mt-3 rounded-lg border p-3 {% if repo.hasOpenAlertOlderThan14Days %}bg-red-50 dark:bg-red-950/20 border-red-500 dark:border-red-500 border-2{% else %}border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900/50{% endif %}">
                <details class="group/alerts">
                  <summary class="list-none cursor-pointer [&::-webkit-details-marker]:hidden">
                    <div class="flex flex-wrap gap-0 text-[0px]">
                      {% set hasAlerts = repo.criticalSeverityAlerts and repo.criticalSeverityAlerts > 0 %}
                      <div class="inline-block text-sm {% if hasAlerts %}text-white bg-red-600{% else %}text-slate-400 bg-slate-300 dark:text-slate-500 dark:bg-slate-700{% endif %} first:rounded-l-full last:rounded-r-full first:pl-3 last:pr-3 py-1 px-2"><span {% if repo.criticalSeverityAlerts %}class="font-bold"{% endif %}>{{ repo.criticalSeverityAlerts }}</span></div>
                      {% set hasAlerts = repo.highSeverityAlerts and repo.highSeverityAlerts > 0 %}
                      <div class="inline-block text-sm {% if hasAlerts %}text-white bg-red-500{% else %}text-slate-400 bg-slate-300 dark:text-slate-500 dark:bg-slate-700{% endif %} first:rounded-l-full last:rounded-r-full first:pl-3 last:pr-3 py-1 px-2"><span {% if repo.highSeverityAlerts %}class="font-bold"{% endif %}>{{ repo.highSeverityAlerts }}</span></div>
                      {% set hasAlerts = repo.mediumSeverityAlerts and repo.mediumSeverityAlerts > 0 %}
                      <div class="inline-block text-sm {% if hasAlerts %}text-white bg-orange-500{% else %}text-slate-400 bg-slate-300 dark:text-slate-500 dark:bg-slate-700{% endif %} first:rounded-l-full last:rounded-r-full first:pl-3 last:pr-3 py-1 px-2"><span {% if repo.mediumSeverityAlerts %}class="font-bold"{% endif %}>{{ repo.mediumSeverityAlerts }}</span></div>
                      {% set hasAlerts = repo.lowSeverityAlerts and repo.lowSeverityAlerts > 0 %}
                      <div class="inline-block text-sm {% if hasAlerts %}text-white bg-amber-500{% else %}text-slate-400 bg-slate-300 dark:text-slate-500 dark:bg-slate-700{% endif %} first:rounded-l-full last:rounded-r-full first:pl-3 last:pr-3 py-1 px-2"><span {% if repo.lowSeverityAlerts %}class="font-bold"{% endif %}>{{ repo.lowSeverityAlerts }}</span></div>
                    </div>
                    {% if repo.hasOpenAlertOlderThan14Days %}
                    <p class="mt-2 text-sm font-medium text-red-700 dark:text-red-400">
                      Security alert older than 14 days.
                    </p>
                    {% endif %}
                    <div class="flex items-center gap-2 mt-2">
                      <span class="text-xs bg-slate-600 text-white rounded-lg py-0.5 px-2 hidden group-open/alerts:inline">Hide security alert details</span>
                      <span class="text-xs bg-slate-600 text-white rounded-lg py-0.5 px-2 group-open/alerts:hidden">Show security alert details</span>
                    </div>
                  </summary>
                  <div class="mt-2 text-xs text-slate-600 dark:text-slate-300">
                    {% if repo.oldestOpenAlertCreatedAt %}
                    Oldest vulnerability age:
                    <span class="js-alert-age font-semibold" data-created-at="{{ repo.oldestOpenAlertCreatedAt }}"></span>

                    {% if repo.otherOpenAlerts and repo.otherOpenAlerts.length %}
                    <p class="mt-2">Other vulnerabilities:</p>
                    <ul class="mt-1 list-disc pl-5 space-y-1">
                      {% for alert in repo.otherOpenAlerts %}
                      <li>
                        <span class="js-alert-age font-semibold {% if alert.severity === 'critical' %}text-red-700 dark:text-red-400{% endif %}" data-created-at="{{ alert.createdAt }}"></span>
                      </li>
                      {% endfor %}
                    </ul>
                    {% elif repo.otherOpenAlertsCreatedAt and repo.otherOpenAlertsCreatedAt.length %}
                    <p class="mt-2">Other vulnerabilities:</p>
                    <ul class="mt-1 list-disc pl-5 space-y-1">
                      {% for createdAt in repo.otherOpenAlertsCreatedAt %}
                      <li><span class="js-alert-age font-semibold" data-created-at="{{ createdAt }}"></span></li>
                      {% endfor %}
                    </ul>
                    {% endif %}
                    {% else %}
                    No open vulnerabilities.
                    {% endif %}
                  </div>
                </details>
              </div>
              {% else %}
              <p class="mt-1 text-slate-400 text-xs font-light italic">Dependabot alerts disabled</p>
              {% endif %}

              {% if repo.description %}
              <p class="mt-2 text-sm text-slate-700 dark:text-slate-200">{{ repo.description }}</p>
              {% endif %}

              {% if repo.topics.length %}
              <div class="mt-2 flex flex-wrap gap-1">
                {% for topic in repo.topics %}
                {% set topicSelected = topic in selectedTags %}
                <a href="{{ buildTopicFilterUrl(topic) }}" class="text-xs rounded-full py-0.5 px-2 transition-colors {% if topicSelected %}text-white bg-slate-700 dark:text-slate-900 dark:bg-slate-200{% else %}text-slate-600 dark:text-slate-300 bg-slate-200 dark:bg-slate-900 hover:bg-slate-300 dark:hover:bg-slate-800{% endif %}">{{ topic }}</a>
                {% endfor %}
              </div>
              {% endif %}
            </div>

            <!-- Stats -->
            <div class="px-4 py-2 text-sm border-b border-slate-100 dark:border-slate-700">
              <div class="flex items-center gap-4">
                <div>
                  <span class="text-slate-400 text-xs uppercase tracking-wide">Bot PRs</span>
                  <p class="font-semibold">{{ repo.openBotPrCount }}</p>
                </div>
                <div>
                  <span class="text-slate-400 text-xs uppercase tracking-wide">Oldest open PR</span>
                  <p class="font-semibold">{{ repo.oldestOpenPrOpenedAt or "—" }}</p>
                </div>
              </div>
              <details class="mt-1 group/stats">
                <summary class="list-none cursor-pointer [&::-webkit-details-marker]:hidden text-xs text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200">
                  <span class="group-open/stats:hidden bg-slate-100 dark:bg-slate-700 rounded px-2 py-0.5">More stats…</span>
                  <span class="hidden group-open/stats:inline bg-slate-100 dark:bg-slate-700 rounded px-2 py-0.5">Less</span>
                </summary>
                <div class="grid grid-cols-2 gap-x-4 gap-y-1 mt-2">
                  <div>
                    <span class="text-slate-400 text-xs uppercase tracking-wide">Open issues</span>
                    <p class="font-semibold">{{ repo.openIssues }}</p>
                  </div>
                  <div>
                    <span class="text-slate-400 text-xs uppercase tracking-wide">Open PRs</span>
                    <p class="font-semibold">{{ repo.openPrCount }}</p>
                  </div>
                  <div>
                    <span class="text-slate-400 text-xs uppercase tracking-wide">Updated at</span>
                    <p class="font-semibold">{{ repo.updatedAt }}</p>
                  </div>
                  <div>
                    <span class="text-slate-400 text-xs uppercase tracking-wide">Most recent PR</span>
                    <p class="font-semibold">{{ repo.mostRecentPrOpenedAt }}</p>
                  </div>
                  <div>
                    <span class="text-slate-400 text-xs uppercase tracking-wide">Most recent issue</span>
                    <p class="font-semibold">{{ repo.mostRecentIssueOpenedAt }}</p>
                  </div>
                  <div>
                    <span class="text-slate-400 text-xs uppercase tracking-wide">Oldest open issue</span>
                    <p class="font-semibold">{{ repo.oldestOpenIssueOpenedAt }}</p>
                  </div>
                </div>
              </details>
            </div>

            <!-- Last bot PR closed -->
            <div class="mx-4 my-2 flex items-center gap-2 rounded border px-3 py-1.5 text-xs {% if repo.botPrStale %}bg-orange-50 dark:bg-orange-950/30 border-orange-400 dark:border-orange-700 border-2{% else %}border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900/50{% endif %}">
              <i class="bx bx-bot text-sm {% if repo.botPrStale %}text-orange-500 dark:text-orange-400{% else %}text-slate-400 dark:text-slate-500{% endif %}"></i>
              <span class="{% if repo.botPrStale %}text-orange-600 dark:text-orange-400{% else %}text-slate-400 dark:text-slate-500{% endif %} uppercase tracking-wide font-medium">Last bot PR closed</span>
              <span class="font-semibold {% if repo.botPrStale %}text-orange-700 dark:text-orange-300{% else %}text-slate-700 dark:text-slate-200{% endif %}">{{ repo.mostRecentBotPrClosedAt or "—" }}</span>
            </div>

            <!-- Dependencies -->
              {% if repo.dependencies.length %}
            <div class="px-4 pt-2 pb-3 flex-1">
              <div class="group space-y-2">
                <p class="text-sm">
                  {% if repo.dependencies.length === 1 %}
                  <span class="font-bold">1</span> dependency:
                  {% else %}
                  <span class="font-bold">{{ repo.dependencies.length }}</span> dependencies:
                  {% endif %}
                  <label>
                    <input class="hidden" type="checkbox" />
                    <span class="text-xs bg-slate-600 text-white rounded-lg py-0.5 px-2 hidden group-has-[:checked]:inline">Hide</span>
                    <span class="text-xs bg-slate-600 text-white rounded-lg py-0.5 px-2 group-has-[:checked]:hidden">Show</span>
                  </label>
                </p>
                <ul class="space-y-1.5 hidden group-has-[:checked]:block">
                  {% for dependency in repo.dependencies %}
                  <li>
                    <div class="inline-block whitespace-nowrap text-[0px]">
                      <span>
                        <span class="font-mono text-sm bg-{{ dependency.color }}-200 dark:bg-{{ dependency.color }}-600 rounded-l-full last:rounded-r-full py-1 px-2">{{ dependency.name }}</span>
                        {% if dependency.version %}
                        <span class="font-mono text-sm bg-{{ dependency.color }}-300 dark:bg-{{ dependency.color }}-700 last:rounded-r-full py-1 px-2">v{{ dependency.version }}</span>
                        {% endif %}
                        {% if dependency.tag %}
                        <span class="font-mono text-sm bg-{{ dependency.color }}-400 dark:bg-{{ dependency.color }}-800 text-white last:rounded-r-full py-1 px-2">{{ dependency.tag }}</span>
                        {% endif %}
                      </span>
                      <span class="inline-block w-1"></span>
                      <span>
                        {% if dependency.isOutdated %}
                        <span class="font-mono text-sm bg-{{ dependency.color }}-500 dark:bg-{{ dependency.color }}-500 text-white first:rounded-l-full last:rounded-r-full py-1 px-2">
                          <i class="align-[-1px] bx {{dependency.icon}}"></i>
                          {{ dependency.changelog }}
                          v{{ dependency.latestVersion }}
                        </span>
                        {% endif %}
                        {% if dependency.isEndOfLifeSoon %}
                        <span class="font-mono text-sm bg-{{ dependency.color }}-600 dark:bg-{{ dependency.color }}-500 text-white first:rounded-l-full last:rounded-r-full py-1 px-2">
                          <i class="align-[-1px] bx bxs-hourglass"></i>
                          <span class="font-sans">Support ends {{ dependency.endOfLifeRelative }}</span>
                        </span>
                        {% elif dependency.isOutOfSupport %}
                        <span class="font-mono text-sm bg-{{ dependency.color }}-600 dark:bg-{{ dependency.color }}-500 text-white first:rounded-l-full last:rounded-r-full py-1 px-2">
                          <i class="align-[-1px] bx bxs-hourglass-bottom"></i>
                          <span class="font-sans">Support ended {{ dependency.endOfLifeRelative }}</span>
                        </span>
                        {% endif %}
                      </span>
                    </div>
                  </li>
                  {% endfor %}
                </ul>
              </div>
            </div>
              {% endif %}

          </div>
          {% else %}
          <p class="col-span-full py-4 text-center text-slate-400 font-light italic">No repositories found.</p>
           {% endfor %}
        </div>

        <!-- Row view -->
        <div id="row-view" class="mx-4 mb-4 hidden space-y-2">
          {% for repo in repos %}
          <div class="rounded-lg border bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 px-4 py-3">
            <div class="flex flex-wrap items-start gap-x-6 gap-y-2">

              <!-- Name, language, description, topics -->
              <div class="flex-1 min-w-[200px]">
                <div class="flex flex-wrap items-center gap-2">
                  <a target="_blank" class="text-base font-semibold text-slate-600 dark:text-slate-300 hover:underline" href="{{repo.htmlUrl}}">{{ repo.name }}</a>
                  {% if repo.language %}
                  <span class="text-xs text-{{ repo.languageColor }}-600 dark:text-{{ repo.languageColor }}-400 border-{{ repo.languageColor }}-600 dark:border-{{ repo.languageColor }}-400 border rounded-lg py-0.5 px-2">{{ repo.language }}</span>
                  {% endif %}
                </div>
                {% if repo.description %}
                <p class="mt-0.5 text-sm text-slate-600 dark:text-slate-300 line-clamp-1">{{ repo.description }}</p>
                {% endif %}
                {% if repo.topics.length %}
                <div class="mt-1 flex flex-wrap gap-1">
                  {% for topic in repo.topics %}
                  {% set topicSelected = topic in selectedTags %}
                  <a href="{{ buildTopicFilterUrl(topic) }}" class="text-xs rounded-full py-0.5 px-2 transition-colors {% if topicSelected %}text-white bg-slate-700 dark:text-slate-900 dark:bg-slate-200{% else %}text-slate-600 dark:text-slate-300 bg-slate-200 dark:bg-slate-900 hover:bg-slate-300 dark:hover:bg-slate-800{% endif %}">{{ topic }}</a>
                  {% endfor %}
                </div>
                {% endif %}
              </div>

              <!-- Alerts -->
              <div class="w-28">
                {% if repo.totalOpenAlerts !== undefined %}
                <div class="flex flex-wrap gap-0 text-[0px]">
                  {% set hasAlerts = repo.criticalSeverityAlerts and repo.criticalSeverityAlerts > 0 %}
                  <div class="inline-block text-xs {% if hasAlerts %}text-white bg-red-600{% else %}text-slate-400 bg-slate-300 dark:text-slate-500 dark:bg-slate-700{% endif %} first:rounded-l-full last:rounded-r-full first:pl-2 last:pr-2 py-0.5 px-1"><span {% if repo.criticalSeverityAlerts %}class="font-bold"{% endif %}>{{ repo.criticalSeverityAlerts }}</span></div>
                  {% set hasAlerts = repo.highSeverityAlerts and repo.highSeverityAlerts > 0 %}
                  <div class="inline-block text-xs {% if hasAlerts %}text-white bg-red-500{% else %}text-slate-400 bg-slate-300 dark:text-slate-500 dark:bg-slate-700{% endif %} first:rounded-l-full last:rounded-r-full first:pl-2 last:pr-2 py-0.5 px-1"><span {% if repo.highSeverityAlerts %}class="font-bold"{% endif %}>{{ repo.highSeverityAlerts }}</span></div>
                  {% set hasAlerts = repo.mediumSeverityAlerts and repo.mediumSeverityAlerts > 0 %}
                  <div class="inline-block text-xs {% if hasAlerts %}text-white bg-orange-500{% else %}text-slate-400 bg-slate-300 dark:text-slate-500 dark:bg-slate-700{% endif %} first:rounded-l-full last:rounded-r-full first:pl-2 last:pr-2 py-0.5 px-1"><span {% if repo.mediumSeverityAlerts %}class="font-bold"{% endif %}>{{ repo.mediumSeverityAlerts }}</span></div>
                  {% set hasAlerts = repo.lowSeverityAlerts and repo.lowSeverityAlerts > 0 %}
                  <div class="inline-block text-xs {% if hasAlerts %}text-white bg-amber-500{% else %}text-slate-400 bg-slate-300 dark:text-slate-500 dark:bg-slate-700{% endif %} first:rounded-l-full last:rounded-r-full first:pl-2 last:pr-2 py-0.5 px-1"><span {% if repo.lowSeverityAlerts %}class="font-bold"{% endif %}>{{ repo.lowSeverityAlerts }}</span></div>
                </div>
                {% else %}
                <span class="text-xs text-slate-400 italic">No Dependabot</span>
                {% endif %}
              </div>

              <!-- Stats -->
              <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs">
                <div>
                  <span class="text-slate-400 uppercase tracking-wide">Bot PRs</span>
                  <p class="font-semibold text-sm">{{ repo.openBotPrCount }}</p>
                </div>
                <div>
                  <span class="text-slate-400 uppercase tracking-wide">PRs</span>
                  <p class="font-semibold text-sm">{{ repo.openPrCount }}</p>
                </div>
                <div>
                  <span class="text-slate-400 uppercase tracking-wide">Issues</span>
                  <p class="font-semibold text-sm">{{ repo.openIssues }}</p>
                </div>
                <div>
                  <span class="text-slate-400 uppercase tracking-wide">Oldest PR</span>
                  <p class="font-semibold text-sm">{{ repo.oldestOpenPrOpenedAt or "—" }}</p>
                </div>
                <div>
                  <span class="text-slate-400 uppercase tracking-wide">Last bot closed</span>
                  <p class="font-semibold text-sm {% if repo.botPrStale %}text-orange-600 dark:text-orange-400{% endif %}">{{ repo.mostRecentBotPrClosedAt or "—" }}</p>
                </div>
              </div>

              <!-- Dependencies count -->
              <div class="text-xs">
                <span class="text-slate-400 uppercase tracking-wide">Deps</span>
                <p class="font-semibold text-sm">{{ repo.dependencies.length or "—" }}</p>
              </div>

            </div>

            <!-- Expandable sections -->
            <div class="mt-2 flex flex-wrap gap-x-4 gap-y-2 text-xs">
              <!-- More stats -->
              <details class="group/stats">
                <summary class="list-none cursor-pointer [&::-webkit-details-marker]:hidden text-xs text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200">
                  <span class="group-open/stats:hidden bg-slate-100 dark:bg-slate-700 rounded px-2 py-0.5">More stats…</span>
                  <span class="hidden group-open/stats:inline bg-slate-100 dark:bg-slate-700 rounded px-2 py-0.5">Less</span>
                </summary>
                <div class="mt-1.5 flex flex-wrap gap-x-4 gap-y-1">
                  <div>
                    <span class="text-slate-400 uppercase tracking-wide">Updated at</span>
                    <p class="font-semibold text-sm">{{ repo.updatedAt }}</p>
                  </div>
                  <div>
                    <span class="text-slate-400 uppercase tracking-wide">Most recent PR</span>
                    <p class="font-semibold text-sm">{{ repo.mostRecentPrOpenedAt or "—" }}</p>
                  </div>
                  <div>
                    <span class="text-slate-400 uppercase tracking-wide">Most recent issue</span>
                    <p class="font-semibold text-sm">{{ repo.mostRecentIssueOpenedAt or "—" }}</p>
                  </div>
                  <div>
                    <span class="text-slate-400 uppercase tracking-wide">Oldest open issue</span>
                    <p class="font-semibold text-sm">{{ repo.oldestOpenIssueOpenedAt or "—" }}</p>
                  </div>
                </div>
              </details>

              <!-- Dependencies expandable -->
              {% if repo.dependencies.length %}
              <details class="group/deps">
                <summary class="list-none cursor-pointer [&::-webkit-details-marker]:hidden text-xs text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200">
                  <span class="group-open/deps:hidden bg-slate-100 dark:bg-slate-700 rounded px-2 py-0.5">Show dependencies…</span>
                  <span class="hidden group-open/deps:inline bg-slate-100 dark:bg-slate-700 rounded px-2 py-0.5">Hide dependencies</span>
                </summary>
                <ul class="mt-1.5 flex flex-wrap gap-1.5">
                  {% for dependency in repo.dependencies %}
                  <li class="inline-block whitespace-nowrap text-[0px]">
                    <span class="font-mono text-xs bg-{{ dependency.color }}-200 dark:bg-{{ dependency.color }}-600 rounded-l-full last:rounded-r-full py-0.5 px-2">{{ dependency.name }}</span>
                    {% if dependency.version %}
                    <span class="font-mono text-xs bg-{{ dependency.color }}-300 dark:bg-{{ dependency.color }}-700 last:rounded-r-full py-0.5 px-2">v{{ dependency.version }}</span>
                    {% endif %}
                    {% if dependency.isOutdated %}
                    <span class="font-mono text-xs bg-{{ dependency.color }}-500 dark:bg-{{ dependency.color }}-500 text-white last:rounded-r-full py-0.5 px-2">
                      <i class="align-[-1px] bx {{dependency.icon}}"></i> v{{ dependency.latestVersion }}
                    </span>
                    {% endif %}
                  </li>
                  {% endfor %}
                </ul>
              </details>
              {% endif %}
            </div>

          </div>
          {% else %}
          <p class="py-4 text-center text-slate-400 font-light italic">No repositories found.</p>
          {% endfor %}
        </div>

        <!-- Pagination -->
        {% if totalPages > 1 %}
        {{macros.pagination(currentPage, pageNumbers, totalPages, baseUrl, sortBy, sortDirection, tag, alertFilter)}}
        {% endif %}
      </div>
    </div>
    <script>
      const toggle = document.getElementById('theme-toggle');
      const icon = document.getElementById('theme-icon');
      function applyTheme() {
        const isDark = document.documentElement.classList.contains('dark');
        icon.className = 'bx text-xl ' + (isDark ? 'bx-sun' : 'bx-moon');
      }
      applyTheme();
      toggle.addEventListener('click', () => {
        document.documentElement.classList.toggle('dark');
        localStorage.theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
        applyTheme();
      });

      document.querySelectorAll('.js-alert-age').forEach((element) => {
        const createdAt = element.dataset.createdAt;
        if (!createdAt) return;

        const createdAtDate = new Date(createdAt);
        const now = new Date();
        const ageInDays = Math.floor((now.getTime() - createdAtDate.getTime()) / (24 * 60 * 60 * 1000));

        if (ageInDays === 1) {
          element.textContent = '1 day';
          return;
        }

        element.textContent = `${ageInDays} days`;
      });

      // View toggle (cards/rows)
      const cardView = document.getElementById('card-view');
      const rowView = document.getElementById('row-view');
      const btnCards = document.getElementById('view-cards');
      const btnRows = document.getElementById('view-rows');
      const activeClass = 'bg-slate-700 text-white dark:bg-slate-200 dark:text-slate-900';
      const inactiveClass = 'bg-slate-200 text-slate-700 hover:bg-slate-300 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700';

      function setView(view, navigate) {
        if (view === 'rows') {
          cardView.classList.add('hidden');
          rowView.classList.remove('hidden');
          btnRows.className = `px-3 py-1 flex items-center gap-1 transition-colors ${activeClass}`;
          btnCards.className = `px-3 py-1 flex items-center gap-1 transition-colors ${inactiveClass}`;
        } else {
          cardView.classList.remove('hidden');
          rowView.classList.add('hidden');
          btnCards.className = `px-3 py-1 flex items-center gap-1 transition-colors ${activeClass}`;
          btnRows.className = `px-3 py-1 flex items-center gap-1 transition-colors ${inactiveClass}`;
        }
        localStorage.towtruckView = view;

        if (navigate) {
          const url = new URL(window.location.href);
          if (view === 'rows') {
            url.searchParams.set('view', 'rows');
          } else {
            url.searchParams.delete('view');
          }
          url.searchParams.delete('page');
          window.location.href = url.toString();
        }
      }

      btnCards.addEventListener('click', () => setView('cards', true));
      btnRows.addEventListener('click', () => setView('rows', true));

      // Apply saved view on load (without navigating if already correct)
      const currentView = new URLSearchParams(window.location.search).get('view');
      if (localStorage.towtruckView === 'rows' && currentView !== 'rows') {
        setView('rows', true);
      } else if (localStorage.towtruckView === 'rows') {
        setView('rows', false);
      }
    </script>
  </body>
</html>
