{
  "name": "towtruck",
  "version": "0.0.1",
  "description": "for keeping on top of dxw's repos",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node --env-file=.env index.js",
    "start:watch": "node --env-file=.env --watch index.js",
    "test": "node --test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "seed": "npm run seed:repos && npm run seed:lifetimes",
    "seed:repos": "node --env-file=.env ./seed/repos.js",
    "seed:lifetimes": "node --env-file=.env ./seed/lifetimes.js",
    "notify:slack": "node --env-file=.env ./script/notify-slack-stale-bot-prs.js"
  },
  "author": "dxw",
  "license": "MIT",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@octokit/app": "^16.1.0",
    "better-sqlite3": "^12.11.0",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "express": "^5.0.0",
    "express-session": "^1.19.0",
    "nunjucks": "^3.2.4",
    "openid-client": "^6.8.4",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "24.13.2",
    "chokidar": "3.6.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
