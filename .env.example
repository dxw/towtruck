APP_ID=123456
PRIVATE_KEY= # Use `script/encode-key <path-to-pem-file>` to encode the private key 
CLIENT_ID=SomeClientId123
CLIENT_SECRET=secret
WEBHOOK_SECRET=secret
REDIRECT_URL_BASE=http://localhost:3000
GOOGLE_CLIENT_ID= # OAuth 2.0 client ID from Google Cloud Console
GOOGLE_CLIENT_SECRET= # OAuth 2.0 client secret from Google Cloud Console
SESSION_SECRET= # Long random string, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BASE_URL=http://localhost:3000 # Public base URL of the app, no trailing slash. Authorised redirect URI in Google Cloud Console should be set to <BASE_URL>/auth/callback
