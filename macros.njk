{% macro sortableCardHeader(name, id, sortDirection, sortBy, basePath) %}

{% set basePath = basePath if basePath else "/" %}
{% set sortingOnThisParam = id === sortBy %}
{% set linkParams = basePath + "?sortBy=" + id + "&sortDirection=asc" %}
{% set ariaSort = "none" %}

{% if sortingOnThisParam and sortDirection === "asc" %}
    {% set linkParams = basePath + "?sortBy=" + id + "&sortDirection=desc" %}
    {% set ariaSort = "ascending" %}
{% endif %}

{% if sortingOnThisParam and sortDirection === "desc" %}
    {% set linkParams = basePath + "?sortBy=" + id + "&sortDirection=asc" %}
    {% set ariaSort = "descending" %}
{% endif %}

<a href="{{linkParams}}" aria-sort="{{ariaSort}}"
   class="inline-flex items-center gap-1 rounded-full border px-3 py-1 text-sm font-medium transition-colors
          {% if sortingOnThisParam %}bg-slate-700 text-white border-slate-700 dark:bg-slate-200 dark:text-slate-900 dark:border-slate-200
          {% else %}bg-slate-200 text-slate-700 border-slate-400 hover:bg-slate-300 dark:bg-slate-800 dark:text-slate-200 dark:border-slate-600 dark:hover:bg-slate-700{% endif %}">
  {{name}}
  <span class="text-xs">
    {% if sortingOnThisParam and sortDirection === "asc" %}↓
    {% elif sortingOnThisParam and sortDirection === "desc" %}↑
    {% else %}<span class="opacity-40">↕</span>
    {% endif %}
  </span>
</a>
{% endmacro %}

{% macro sortableTableHeader(name, id, sortDirection, sortBy) %}

{% set upArrow %}
    <svg class="inline-block h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
    </svg>
{%endset%}

{% set downArrow %}
    <svg class="inline-block h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
    </svg>
{%endset%}
    
    
{% set sortingOnThisParam = id === sortBy %}
{% set linkParams = "?sortBy=" + id + "&sortDirection=asc" %}
{%set ariaSort = "none"%}

{%if sortingOnThisParam and sortDirection === "asc"%}
    {% set linkParams = "?sortBy=" + id + "&sortDirection=desc" %}
    {%set ariaSort = "ascending"%}
{%endif%}

{%if sortingOnThisParam and sortDirection === "desc"%}
    {% set linkParams = "?sortBy=" + id + "&sortDirection=asc" %}
    {%set ariaSort = "descending"%}
{%endif%}



<th class="py-2 pl-2" scope="col" aria-sort="{{ariaSort}}"><a href="/{{linkParams}}"> {{name}}

    <span class="text-xs ml-1 whitespace-nowrap">
        {% if sortDirection === "asc" and sortingOnThisParam %}
        <div class="w-full">
            {{upArrow | safe}}
        </div>
        {% elseif sortDirection === 'desc' and sortingOnThisParam %}
        <div class="w-full">
            {{downArrow | safe}}
        </div>
        {% elseif id !== sortBy %}
        <div class="w-full">
            {{upArrow | safe}}
            {{downArrow | safe}}
        </div>
        {% endif %}
    </span>
</a>
</th>
{% endmacro %}

{% macro tooltip(id, mainText, tooltipText) %}
<div aria-describedby="{{ id }}" class="group relative inline-block">
  <span class="border-dotted border-b">{{ mainText }}</span>
  <div role="tooltip" id="{{ id }}" class="invisible group-focus:visible group-hover:visible absolute -top-8 left-2/4 -translate-x-2/4 text-center z-30 py-0.5 px-2 bg-slate-900 text-white rounded-full after:content-[' '] after:absolute after:top-full after:left-2/4 after:-ml-[4px] after:border-4 after:border-transparent after:border-t-slate-900">
    {{ tooltipText }}
  </div>
</div>
{% endmacro %}

{% macro pagination(currentPage, pageNumbers, totalPages, basePath, sortBy, sortDirection, tag) %}
{% set basePath = basePath if basePath else "/" %}
<nav class="flex justify-center items-center gap-2 my-6" aria-label="Pagination">
  <!-- Previous button -->
  {% if currentPage > 1 %}
    {% set prevParams = basePath + "?page=" + (currentPage - 1) %}
    {% if sortBy %}{% set prevParams = prevParams + "&sortBy=" + sortBy %}{% endif %}
    {% if sortDirection %}{% set prevParams = prevParams + "&sortDirection=" + sortDirection %}{% endif %}
    {% if tag %}{% set prevParams = prevParams + "&tag=" + tag %}{% endif %}
    <a href="{{ prevParams }}" class="px-4 py-2 rounded-lg border border-slate-400 bg-slate-200 text-slate-700 hover:bg-slate-300 dark:bg-slate-800 dark:text-slate-200 dark:border-slate-600 dark:hover:bg-slate-700 transition-colors" aria-label="Previous page">
      <i class="bx bx-chevron-left"></i>
    </a>
  {% else %}
    <button disabled class="px-4 py-2 rounded-lg border border-slate-300 bg-slate-100 text-slate-400 dark:bg-slate-900 dark:text-slate-600 dark:border-slate-700 cursor-not-allowed" aria-label="Previous page">
      <i class="bx bx-chevron-left"></i>
    </button>
  {% endif %}

  <!-- Page numbers -->
  <div class="flex gap-1">
    {% for pageNum in pageNumbers %}
      {% if pageNum === currentPage %}
        <span class="px-3 py-2 rounded-lg border-2 border-slate-700 bg-slate-700 text-white dark:border-slate-200 dark:bg-slate-200 dark:text-slate-900 font-semibold" aria-current="page">
          {{ pageNum }}
        </span>
      {% else %}
        {% set pageParams = basePath + "?page=" + pageNum %}
        {% if sortBy %}{% set pageParams = pageParams + "&sortBy=" + sortBy %}{% endif %}
        {% if sortDirection %}{% set pageParams = pageParams + "&sortDirection=" + sortDirection %}{% endif %}
        {% if tag %}{% set pageParams = pageParams + "&tag=" + tag %}{% endif %}
        <a href="{{ pageParams }}" class="px-3 py-2 rounded-lg border border-slate-400 bg-slate-200 text-slate-700 hover:bg-slate-300 dark:bg-slate-800 dark:text-slate-200 dark:border-slate-600 dark:hover:bg-slate-700 transition-colors">
          {{ pageNum }}
        </a>
      {% endif %}
    {% endfor %}
  </div>

  <!-- Next button -->
  {% if currentPage < totalPages %}
    {% set nextParams = basePath + "?page=" + (currentPage + 1) %}
    {% if sortBy %}{% set nextParams = nextParams + "&sortBy=" + sortBy %}{% endif %}
    {% if sortDirection %}{% set nextParams = nextParams + "&sortDirection=" + sortDirection %}{% endif %}
    {% if tag %}{% set nextParams = nextParams + "&tag=" + tag %}{% endif %}
    <a href="{{ nextParams }}" class="px-4 py-2 rounded-lg border border-slate-400 bg-slate-200 text-slate-700 hover:bg-slate-300 dark:bg-slate-800 dark:text-slate-200 dark:border-slate-600 dark:hover:bg-slate-700 transition-colors" aria-label="Next page">
      <i class="bx bx-chevron-right"></i>
    </a>
  {% else %}
    <button disabled class="px-4 py-2 rounded-lg border border-slate-300 bg-slate-100 text-slate-400 dark:bg-slate-900 dark:text-slate-600 dark:border-slate-700 cursor-not-allowed" aria-label="Next page">
      <i class="bx bx-chevron-right"></i>
    </button>
  {% endif %}
</nav>
{% endmacro %}

